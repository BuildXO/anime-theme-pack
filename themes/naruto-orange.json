  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6B5F4F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Block",
      "scope": [
        "comment.block",
        "comment.line"
      ],
      "settings": {
        "foreground": "#6B5F4F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation Comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation"
      ],
      "settings": {
        "foreground": "#8B949E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.alignof",
        "keyword.operator.typeid",
        "keyword.operator.alignas",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python"
      ],
      "settings": {
        "foreground": "#FF8C00"
      }
    },
    {
      "name": "Control Flow Keywords",
      "scope": [
        "keyword.control.conditional",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.return",
        "keyword.control.as",
        "keyword.control.from",
        "keyword.control.export",
        "keyword.control.default"
      ],
      "settings": {
        "foreground": "#FFA500"
      }
    },
    {
      "name": "Storage Type & Modifiers",
      "scope": [
        "storage.type",
        "storage.modifier",
        "storage.type.class",
        "storage.type.function",
        "storage.type.property",
        "storage.type.enum",
        "storage.type.interface",
        "storage.type.namespace",
        "storage.type.struct"
      ],
      "settings": {
        "foreground": "#FF8C00"
      }
    },
    {
      "name": "Function Declarations",
      "scope": [
        "entity.name.function",
        "entity.name.method",
        "meta.function-call entity.name.function",
        "meta.method-call entity.name.function"
      ],
      "settings": {
        "foreground": "#9370DB"
      }
    },
    {
      "name": "Function Calls",
      "scope": [
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#9370DB"
      }
    },
    {
      "name": "Method Calls",
      "scope": [
        "meta.method.call",
        "meta.function.call.member"
      ],
      "settings": {
        "foreground": "#9370DB"
      }
    },
    {
      "name": "Built-in Functions",
      "scope": [
        "support.function.builtin",
        "support.function.console",
        "support.function.magic"
      ],
      "settings": {
        "foreground": "#4169E1"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#BC8CFF"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Object Properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "variable.other.member",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#4169E1"
      }
    },
    {
      "name": "Object Member Accessor",
      "scope": [
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#FF8C00"
      }
    },
    {
      "name": "Language Variables",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#FF8C00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#FFB847"
      }
    },
    {
      "name": "Language Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.none",
        "constant.language.nil"
      ],
      "settings": {
        "foreground": "#FFB847"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.binary",
        "constant.numeric.octal",
        "constant.numeric.decimal"
      ],
      "settings": {
        "foreground": "#00CED1"
      }
    },
    {
      "name": "Character Escape Sequences",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#00CED1"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple"
      ],
      "settings": {
        "foreground": "#F0E68C"
      }
    },
    {
      "name": "Template Strings",
      "scope": [
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#F0E68C"
      }
    },
    {
      "name": "Template Expression",
      "scope": [
        "meta.template.expression",
        "meta.embedded"
      ],
      "settings": {
        "foreground": "#F5E6D3"
      }
    },
    {
      "name": "String Interpolation Punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#FF8C00"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp",
        "constant.character.escape.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#32CD32"
      }
    },
    {
      "name": "Regex Character Class",
      "scope": [
        "constant.other.character-class.set.regexp",
        "punctuation.definition.character-class.regexp"
      ],
      "settings": {
        "foreground": "#F0E68C"
      }
    },
    {
      "name": "Regex Quantifier",
      "scope": [
        "keyword.operator.quantifier.regexp"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Interfaces",
      "scope": [
        "entity.name.type.interface",
        "entity.name.interface"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Structs",
      "scope": [
        "entity.name.type.struct",
        "storage.type.struct"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Enums",
      "scope": [
        "entity.name.type.enum",
        "storage.type.enum"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Enum Members",
      "scope": [
        "variable.other.enummember",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#FFB847"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.type.primitive"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Built-in Types",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "keyword.type"
      ],
      "settings": {
        "foreground": "#4169E1"
      }
    },
    {
      "name": "Type Parameters (Generics)",
      "scope": [
        "entity.name.type.parameter",
        "meta.type.parameters entity.name.type"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Namespaces & Modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.type.namespace",
        "entity.name.type.module",
        "storage.type.namespace"
      ],
      "settings": {
        "foreground": "#F5E6D3"
      }
    },
    {
      "name": "Imports & Exports",
      "scope": [
        "meta.import",
        "meta.export",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#FF8C00"
      }
    },
    {
      "name": "Import/Export Variable",
      "scope": [
        "variable.other.readwrite.alias",
        "meta.import variable.other"
      ],
      "settings": {
        "foreground": "#4169E1"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.bitwise",
        "keyword.operator.increment",
        "keyword.operator.decrement"
      ],
      "settings": {
        "foreground": "#FF8C00"
      }
    },
    {
      "name": "Operator Symbols",
      "scope": [
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.optional"
      ],
      "settings": {
        "foreground": "#FF8C00"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#C5B8A8"
      }
    },
    {
      "name": "Brackets",
      "scope": [
        "punctuation.section.brackets",
        "punctuation.section.parens",
        "punctuation.section.braces",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly"
      ],
      "settings": {
        "foreground": "#C5B8A8"
      }
    },
    {
      "name": "Decorators & Annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute"
      ],
      "settings": {
        "foreground": "#4169E1"
      }
    },
    {
      "name": "Preprocessor Directives",
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive",
        "entity.name.function.preprocessor"
      ],
      "settings": {
        "foreground": "#8B949E"
      }
    },
    {
      "name": "Macros",
      "scope": [
        "entity.name.function.macro",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Labels",
      "scope": [
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Invalid & Deprecated",
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#DC143C"
      }
    },
    {
      "name": "JSX/TSX Tags",
      "scope": [
        "entity.name.tag.tsx",
        "entity.name.tag.jsx",
        "support.class.component.tsx",
        "support.class.component.jsx"
      ],
      "settings": {
        "foreground": "#32CD32"
      }
    },
    {
      "name": "JSX/TSX Tag Brackets",
      "scope": [
        "punctuation.definition.tag.jsx",
        "punctuation.definition.tag.tsx",
        "punctuation.section.embedded.begin.jsx",
        "punctuation.section.embedded.end.jsx"
      ],
      "settings": {
        "foreground": "#8B949E"
      }
    },
    {

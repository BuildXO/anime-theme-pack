{
  "name": "Cyberpunk: Edgerunners (Moon & Lucy)",
  "type": "dark",
  "colors": {
    "editor.background": "#070B11",
    "editor.foreground": "#E6ECFF",
    "editor.lineHighlightBackground": "#121829",
    "editorLineNumber.foreground": "#3E455C",
    "editorLineNumber.activeForeground": "#39FF66",
    "sideBar.background": "#05080D",
    "sideBar.foreground": "#E6ECFF",
    "sideBarTitle.foreground": "#E6ECFF",
    "sideBarSectionHeader.foreground": "#E6ECFF",
    "statusBar.background": "#05080D",
    "activityBar.background": "#05080D",
    "activityBar.foreground": "#FF2D6F",
    "editorCursor.foreground": "#53FF7A",
    "editorCursor.background": "#53FF7A80",
    "editor.selectionBackground": "#2CFF8A33",
    "editor.selectionHighlightBackground": "#B980FF26",
    "titleBar.activeBackground": "#05080D",
    "titleBar.activeForeground": "#E6ECFF",
    "titleBar.inactiveBackground": "#05080D",
    "titleBar.inactiveForeground": "#8891A5",
    "titleBar.border": "#121829",
    "terminal.background": "#070B11",
    "terminal.foreground": "#E6ECFF",
    "list.inactiveSelectionForeground": "#E6ECFF",
    "list.activeSelectionBackground": "#121E35",
    "list.activeSelectionForeground": "#F1F5FF",
    "editorWidget.foreground": "#E6ECFF",
    "focusBorder": "#5D4EFF",
    "editor.focusedStackFrameHighlightBackground": "#39FF6622",
    "tree.indentGuidesStroke": "#3E455C",
    "panel.foreground": "#E6ECFF",
    "panelTitle.activeForeground": "#E6ECFF",
    "panelTitle.inactiveForeground": "#8891A5",
    "editorBracketHighlight.foreground1": "#53FF7A",
    "editorBracketHighlight.foreground2": "#24E8FF",
    "editorBracketHighlight.foreground3": "#B980FF",
    "editorBracketHighlight.foreground4": "#FF4D8D",
    "editorBracketHighlight.foreground5": "#FFD166",
    "editorBracketHighlight.foreground6": "#FF9D1C",
    "editorBracketHighlight.unexpectedBracket.foreground": "#FF5A5A",
    "editorBracketMatch.background": "#B980FF1F",
    "editorBracketMatch.border": "#B980FF"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7A8294",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Block",
      "scope": [
        "comment.block",
        "comment.line"
      ],
      "settings": {
        "foreground": "#7A8294",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation Comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation"
      ],
      "settings": {
        "foreground": "#8A93A6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.alignof",
        "keyword.operator.typeid",
        "keyword.operator.alignas",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python"
      ],
      "settings": {
        "foreground": "#B980FF"
      }
    },
    {
      "name": "Control Flow Keywords",
      "scope": [
        "keyword.control.conditional",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.return",
        "keyword.control.as",
        "keyword.control.from",
        "keyword.control.export",
        "keyword.control.default"
      ],
      "settings": {
        "foreground": "#B980FF"
      }
    },
    {
      "name": "Storage Type & Modifiers",
      "scope": [
        "storage.type",
        "storage.modifier",
        "storage.type.class",
        "storage.type.function",
        "storage.type.property",
        "storage.type.enum",
        "storage.type.interface",
        "storage.type.namespace",
        "storage.type.struct"
      ],
      "settings": {
        "foreground": "#B980FF"
      }
    },
    {
      "name": "Function Declarations",
      "scope": [
        "entity.name.function",
        "entity.name.method",
        "meta.function-call entity.name.function",
        "meta.method-call entity.name.function"
      ],
      "settings": {
        "foreground": "#24E8FF"
      }
    },
    {
      "name": "Function Calls",
      "scope": [
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#24E8FF"
      }
    },
    {
      "name": "Method Calls",
      "scope": [
        "meta.method.call",
        "meta.function.call.member"
      ],
      "settings": {
        "foreground": "#24E8FF"
      }
    },
    {
      "name": "Built-in Functions",
      "scope": [
        "support.function.builtin",
        "support.function.console",
        "support.function.magic"
      ],
      "settings": {
        "foreground": "#00D7FF"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#FF4D8D"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#FFB366"
      }
    },
    {
      "name": "Object Properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "variable.other.member",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#8BD7FF"
      }
    },
    {
      "name": "Object Member Accessor",
      "scope": [
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#B980FF"
      }
    },
    {
      "name": "Language Variables",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#FF2D6F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#FF8E72"
      }
    },
    {
      "name": "Language Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.none",
        "constant.language.nil"
      ],
      "settings": {
        "foreground": "#FF8E72"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.binary",
        "constant.numeric.octal",
        "constant.numeric.decimal"
      ],
      "settings": {
        "foreground": "#FF9D1C"
      }
    },
    {
      "name": "Character Escape Sequences",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#5FFFD4"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple"
      ],
      "settings": {
        "foreground": "#F7F38B"
      }
    },
    {
      "name": "Template Strings",
      "scope": [
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#F7F38B"
      }
    },
    {
      "name": "Template Expression",
      "scope": [
        "meta.template.expression",
        "meta.embedded"
      ],
      "settings": {
        "foreground": "#E6ECFF"
      }
    },
    {
      "name": "String Interpolation Punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#B980FF"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp",
        "constant.character.escape.regexp",
        "constant.other.character-class.regexp"

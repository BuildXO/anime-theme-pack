{
  "name": "Jujutsu Night (Gojo Edition)",
  "type": "dark",
  "colors": {
    "editor.background": "#0D1117", 
    "editor.foreground": "#C9D1D9",
    "sideBar.background": "#090C10",
    "sideBar.foreground": "#8B949E",
    "activityBar.background": "#090C10",
    "activityBar.foreground": "#58A6FF", 
    "activityBar.inactiveForeground": "#484F58",
    "statusBar.background": "#090C10",
    "statusBar.foreground": "#8B949E",
    "editorCursor.foreground": "#58A6FF", 
    "editor.selectionBackground": "#58A6FF33",
    "editor.lineHighlightBackground": "#161B22",
    "editorLineNumber.foreground": "#484F58",
    "editorLineNumber.activeForeground": "#58A6FF",
    "terminal.background": "#0D1117",
    "terminal.foreground": "#C9D1D9",
    "terminal.ansiBlue": "#58A6FF",
    "terminal.ansiCyan": "#39C5BB",
    "terminal.ansiMagenta": "#BC8CFF", 
    "list.activeSelectionBackground": "#58A6FF22",
    "list.activeSelectionForeground": "#58A6FF",
    "list.hoverBackground": "#161B22"
  },
  "tokenColors": [
    {
      "name": "Comments (Muted Veil)",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6E7681",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords (Limitless Blue)",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#58A6FF"
      }
    },
    {
      "name": "Strings (Moonlit Sky)",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#A5D6FF"
      }
    },
    {
      "name": "Functions (Hollow Purple)",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#D2A8FF"
      }
    },
    {
      "name": "Variables (Standard Technique)",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#C9D1D9"
      }
    },
    {
      "name": "Numbers (Cursed Energy Spark)",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#FF7B72"
      }
    },
    {
      "name": "Constants (Infinity)",
      "scope": "constant.language",
      "settings": {
        "foreground": "#79C0FF"
      }
    },
    {
      "name": "Types (Reverse Cursed Technique)",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#FFA657"
      }
    },
    {
      "name": "Markup Heading (Domain Expansion)",
      "scope": "markup.heading",
      "settings": {
        "foreground": "#58A6FF",
        "fontStyle": "bold"
      }
    }
  ]
}
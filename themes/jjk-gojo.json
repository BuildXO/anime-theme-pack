  "tokenColors": [
    {
      "name": "Comments (Muted Veil)",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6E7681",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords (Limitless Blue)",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#58A6FF"
      }
    },
    {
      "name": "Strings (Moonlit Sky)",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#A5D6FF"
      }
    },
    {
      "name": "Functions (Hollow Purple)",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#D2A8FF"
      }
    },
    {
      "name": "Variables (Standard Technique)",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#C9D1D9"
      }
    },
    {
      "name": "Numbers (Cursed Energy Spark)",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#FF7B72"
      }
    },
    {
      "name": "Constants (Infinity)",
      "scope": "constant.language",
      "settings": {
        "foreground": "#79C0FF"
      }
    },
    {
      "name": "Types (Reverse Cursed Technique)",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#FFA657"
      }
    },
    {
      "name": "Markup Heading (Domain Expansion)",
      "scope": "markup.heading",
      "settings": {
        "foreground": "#58A6FF",
        "fontStyle": "bold"
      }
    }
  ]
}
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#C8BAAD"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#C0392B"
      }
